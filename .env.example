# Matrix server name (used for Matrix IDs)
MATRIX_SERVER_NAME=matrix.localhost

# Published images used by the stack.
MINDROOM_TUWUNEL_IMAGE=ghcr.io/mindroom-ai/mindroom-tuwunel:latest
MINDROOM_CLIENT_IMAGE=ghcr.io/mindroom-ai/mindroom-cinny:latest

# MindRoom client homeserver URL (what your browser connects to)
# Use http://<host-ip>:8008 when accessing from another device.
CLIENT_HOMESERVER_URL=http://localhost:8008

# AI Provider API Keys (set at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Ollama (optional)
OLLAMA_HOST=http://localhost:11434

# Logging
LOG_LEVEL=INFO
