# Matrix server name (used for Matrix IDs)
MATRIX_SERVER_NAME=matrix.localhost

# Host ports exposed by docker compose. Change these if 8008/8080/8765 are
# already taken on your machine.
HOST_HOMESERVER_PORT=8008
HOST_CLIENT_PORT=8080
HOST_DASHBOARD_PORT=8765

# Published images used by the stack.
MINDROOM_IMAGE=ghcr.io/mindroom-ai/mindroom:latest
MINDROOM_TUWUNEL_IMAGE=ghcr.io/mindroom-ai/mindroom-tuwunel:latest
MINDROOM_CLIENT_IMAGE=ghcr.io/mindroom-ai/mindroom-cinny:latest

# MindRoom client homeserver URL (what your browser connects to)
# Use http://<host-ip>:8008 when accessing from another device.
CLIENT_HOMESERVER_URL=http://localhost:8008

# MindRoom dashboard URL shown inside the client sidebar.
CLIENT_MINDROOM_URL=http://localhost:8765

# AI Provider API Keys (set at least one)
# Fastest path: set ANTHROPIC_API_KEY only.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Ollama (optional)
OLLAMA_HOST=http://localhost:11434

# Logging
LOG_LEVEL=INFO
